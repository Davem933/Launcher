{
  "version": 8,
  "name": "CarLauncher Dark",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "pmtiles://file:///android_asset/maps/czech-republic.pmtiles"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#0D0D0F"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#1A2535"
      }
    },
    {
      "id": "landuse-park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["in", "class", "park", "forest", "grass", "meadow"],
      "paint": {
        "fill-color": "#141A14"
      }
    },
    {
      "id": "road-residential",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "residential", "unclassified", "service"],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#161618",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1, 18, 4]
      }
    },
    {
      "id": "road-secondary-tertiary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "secondary", "tertiary"],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#1A1A1F",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 1, 18, 6]
      }
    },
    {
      "id": "road-primary-trunk",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "trunk"],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#1E2E1E",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1, 18, 10]
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "motorway"],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#2A3A2A",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 1, 14, 6, 18, 14]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "paint": {
        "fill-color": "#1A1A22",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": 11,
        "symbol-placement": "line"
      },
      "paint": {
        "text-color": "#8A8A9A",
        "text-halo-color": "#0D0D0F",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["in", "class", "city", "town", "village"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 10, 14, 14]
      },
      "paint": {
        "text-color": "#F0F0F5",
        "text-halo-color": "#0D0D0F",
        "text-halo-width": 1.5
      }
    }
  ]
}
